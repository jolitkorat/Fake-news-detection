# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/truthlens

# JWT
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_refresh_secret_key_here
JWT_REFRESH_EXPIRE=30d

# OpenAI
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=

# Anakin scraping provider
ANAKIN_API_KEY=your-anakin-key-here
ANAKIN_API_URL=https://api.anakin.io/v1/url-scraper
ANAKIN_SEARCH_URL=https://api.anakin.io/v1/search
ANAKIN_USE_BROWSER=true
ANAKIN_OUTPUT_FORMAT=markdown

# News/Fact Check APIs
NEWS_API_KEY=your-news-api-key-here
GOOGLE_FACT_CHECK_API_KEY=your-google-fact-check-api-key-here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
FRONTEND_URLS=http://localhost:5173,https://your-frontend.vercel.app

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Encryption
API_KEY_SECRET=your_api_key_encryption_secret
